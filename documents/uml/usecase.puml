@startuml
left to right direction

actor "Гость" as Guest
actor "Покупатель" as Customer
actor "Администратор" as Admin

rectangle "Онлайн-магазин одежды" {

  Guest -- (Просмотр каталога)

  Customer -- (Регистрация / Авторизация)
  Customer -- (Просмотр каталога)
  Customer -- (Фильтрация товаров)
  Customer -- (Добавление в корзину)
  Customer -- (Оформление заказа)
  Customer -- (Просмотр истории заказов)
  Customer -- (Использование бонусов)

  Admin -- (Управление товарами)
  Admin -- (Управление категориями)
  Admin -- (Обработка заказов)
  Admin -- (Изменение статуса заказа)
}

@enduml